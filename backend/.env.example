DATABASE_URL=postgresql://appdash:appdash@localhost:5432/appdash
# Separate database for the test suite — create it once with:
#   docker compose exec db createdb -U appdash appdash_test
TEST_DATABASE_URL=postgresql://appdash:appdash@localhost:5432/appdash_test
ANTHROPIC_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me
# Must match a redirect URI registered on the OAuth client in the Google
# Cloud console (as BACKEND_BASE_URL + /auth/google/callback).
BACKEND_BASE_URL=http://localhost:8000
